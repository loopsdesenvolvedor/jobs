              height="200px"
              width="200px"
              xmlns="http://www.w3.org/2000/svg"
            >
              <path d="M128 192l128 128 128-128z"></path>
            </svg>
          </button>
        </div>
      </li>
      <li>
        <div>
          <button class="btn-search">
            <span>Tipo de vaga</span>
            <svg
              stroke="currentColor"
              fill="currentColor"
              stroke-width="0"
